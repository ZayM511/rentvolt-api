{
  "openapi": "3.0.3",
  "info": {
    "title": "RentVolt API",
    "description": "Aggregated rental listing data from multiple sources. Provided by Groundwork Labs LLC (California).",
    "version": "1.1.0",
    "contact": {
      "name": "Groundwork Labs LLC",
      "email": "support@groundworklabs.com"
    }
  },
  "servers": [
    {
      "url": "https://rentvolt-api.onrender.com",
      "description": "Production"
    },
    {
      "url": "http://localhost:3000",
      "description": "Local development"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "summary": "API information and available endpoints",
        "tags": ["Public"],
        "responses": {
          "200": { "description": "API info with endpoint listing" }
        }
      }
    },
    "/health": {
      "get": {
        "summary": "Health check",
        "tags": ["Public"],
        "responses": {
          "200": { "description": "Service status, uptime, and timestamp" }
        }
      }
    },
    "/legal": {
      "get": {
        "summary": "Legal and company information",
        "tags": ["Public"],
        "responses": {
          "200": { "description": "Company info and legal document links" }
        }
      }
    },
    "/api/keys/free": {
      "post": {
        "summary": "Generate a free API key",
        "description": "Generates a free-tier API key (100 requests/month). Rate-limited to 1 key per IP per day.",
        "tags": ["Public"],
        "responses": {
          "200": {
            "description": "API key generated",
            "content": {
              "application/json": {
                "example": {
                  "success": true,
                  "apiKey": "sk_live_abc123...",
                  "plan": "free",
                  "monthlyRequests": 100,
                  "message": "Save this key! You won't be able to retrieve it again.",
                  "docs": "/api-docs"
                }
              }
            }
          },
          "429": { "description": "One free key per day limit reached" }
        }
      }
    },
    "/demo/listings": {
      "get": {
        "summary": "Try the API without authentication",
        "description": "Returns rental listings for a supported city. Rate-limited to 3 requests per IP per 24 hours.",
        "tags": ["Public"],
        "parameters": [
          {
            "name": "city",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "example": "oakland" },
            "description": "City slug (e.g. oakland, san-francisco, new-york)"
          }
        ],
        "responses": {
          "200": {
            "description": "Listings retrieved",
            "content": {
              "application/json": {
                "example": {
                  "success": true,
                  "listings": [
                    { "source": "apartments.com", "price": 2500, "address": "123 Main St, Oakland, CA", "beds": "2 bed", "baths": "1 bath" }
                  ],
                  "total": 5,
                  "sources": { "apartments": 2, "zillow": 3 }
                }
              }
            }
          },
          "400": { "description": "Invalid city" },
          "429": { "description": "Demo rate limit reached (3/day)" }
        }
      }
    },
    "/api/verify": {
      "get": {
        "summary": "Verify API key and check remaining quota",
        "tags": ["Auth"],
        "security": [{ "ApiKeyAuth": [] }],
        "responses": {
          "200": {
            "description": "Key is valid",
            "content": {
              "application/json": {
                "example": { "valid": true, "plan": "growth", "remaining": 950 }
              }
            }
          },
          "401": { "description": "Missing API key" },
          "403": { "description": "Invalid API key" }
        }
      }
    },
    "/api/scrape/listings": {
      "post": {
        "summary": "Get rental listings for a city",
        "tags": ["Scrape"],
        "security": [{ "ApiKeyAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ScrapeRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Listings retrieved",
            "content": {
              "application/json": {
                "example": {
                  "success": true,
                  "listings": [
                    { "source": "apartments.com", "price": 2500, "address": "123 Main St, CA", "beds": "2 bed", "baths": "1 bath" }
                  ],
                  "total": 40,
                  "sources": { "apartments": 10, "zillow": 10 },
                  "query": { "city": "oakland", "state": "ca" },
                  "meta": {
                    "requestId": "abc-123",
                    "plan": "growth",
                    "remaining": 999
                  }
                }
              }
            }
          },
          "400": { "description": "Validation error" },
          "429": { "description": "Rate limit or quota exceeded" }
        }
      }
    },
    "/api/scrape/bulk": {
      "post": {
        "summary": "Bulk scrape multiple cities (paid plans only: Growth/Scale/Enterprise)",
        "tags": ["Scrape"],
        "security": [{ "ApiKeyAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["locations"],
                "properties": {
                  "locations": {
                    "type": "array",
                    "maxItems": 10,
                    "items": {
                      "type": "object",
                      "properties": {
                        "city": { "type": "string" },
                        "state": { "type": "string" }
                      },
                      "required": ["city", "state"]
                    }
                  },
                  "filters": { "$ref": "#/components/schemas/Filters" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bulk results",
            "content": {
              "application/json": {
                "example": {
                  "success": true,
                  "results": [
                    { "city": "oakland", "state": "ca", "success": true, "listings": [], "total": 20 }
                  ],
                  "totalLocations": 1,
                  "meta": { "requestId": "abc-123", "plan": "scale", "remaining": 4999 }
                }
              }
            }
          },
          "403": { "description": "Free plan cannot use bulk" }
        }
      }
    },
    "/api/scrape/locations": {
      "get": {
        "summary": "Get supported locations and sources",
        "tags": ["Scrape"],
        "responses": {
          "200": { "description": "List of optimized locations and available sources" }
        }
      }
    },
    "/api/stripe/plans": {
      "get": {
        "summary": "List available subscription plans",
        "tags": ["Billing"],
        "responses": {
          "200": {
            "description": "Available plans",
            "content": {
              "application/json": {
                "example": {
                  "free": { "name": "RentVolt Starter", "price": "Free", "monthlyRequests": 100 },
                  "paid": [
                    { "id": "growth", "name": "RentVolt Growth", "price": "$19/mo", "monthlyRequests": 1000 },
                    { "id": "scale", "name": "RentVolt Scale", "price": "$49/mo", "monthlyRequests": 5000 },
                    { "id": "enterprise", "name": "RentVolt Enterprise", "price": "$149/mo", "monthlyRequests": 25000 }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/stripe/checkout": {
      "post": {
        "summary": "Create Stripe checkout session for a paid plan",
        "description": "No authentication required. Redirects to Stripe-hosted checkout page.",
        "tags": ["Billing"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["plan"],
                "properties": {
                  "plan": { "type": "string", "enum": ["growth", "scale", "enterprise"] }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Checkout session with redirect URL",
            "content": {
              "application/json": {
                "example": {
                  "sessionId": "cs_test_...",
                  "url": "https://checkout.stripe.com/...",
                  "plan": { "name": "RentVolt Growth", "price": "$19/mo", "monthlyRequests": 1000 }
                }
              }
            }
          },
          "400": { "description": "Invalid plan name" }
        }
      }
    },
    "/api/stripe/manage": {
      "post": {
        "summary": "Open Stripe billing portal for subscription management",
        "tags": ["Billing"],
        "security": [{ "ApiKeyAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["customerId"],
                "properties": {
                  "customerId": { "type": "string", "description": "Stripe customer ID" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Billing portal session URL" },
          "400": { "description": "customerId is required" }
        }
      }
    },
    "/api/stripe/webhook": {
      "post": {
        "summary": "Stripe webhook handler",
        "description": "Receives Stripe subscription events. Not intended for direct use.",
        "tags": ["Billing"],
        "responses": {
          "200": { "description": "Webhook received" },
          "400": { "description": "Invalid signature" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key"
      }
    },
    "schemas": {
      "ScrapeRequest": {
        "type": "object",
        "required": ["city", "state"],
        "properties": {
          "city": { "type": "string", "example": "oakland" },
          "state": { "type": "string", "example": "ca", "minLength": 2, "maxLength": 2 },
          "filters": { "$ref": "#/components/schemas/Filters" }
        }
      },
      "Filters": {
        "type": "object",
        "properties": {
          "sources": { "type": "array", "items": { "type": "string", "enum": ["rentals", "zillow", "apartments", "rentcafe", "hotpads", "zumper"] } },
          "maxPrice": { "type": "integer", "minimum": 0 },
          "minBeds": { "type": "integer", "minimum": 0 },
          "maxBeds": { "type": "integer", "minimum": 0 },
          "sortBy": { "type": "string", "enum": ["price", "source"], "default": "price" },
          "sortOrder": { "type": "string", "enum": ["asc", "desc"], "default": "asc" },
          "limit": { "type": "integer", "minimum": 1, "maximum": 500 }
        }
      }
    }
  }
}
