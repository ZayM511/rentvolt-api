# ─── Server ────────────────────────────────────────────
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_MAX=200

# ─── Database (Render Postgres) ────────────────────────
# Put the REAL "Internal Database URL" from Render in your .env file,
# which is gitignored. DO NOT put real credentials in .env.example —
# this file is committed to git.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# ─── Stripe ────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_GROWTH=price_xxx
STRIPE_PRICE_SCALE=price_xxx
STRIPE_PRICE_ENTERPRISE=price_xxx

# ─── Data sources ──────────────────────────────────────
# Sign up: https://app.rentcast.io/app/api
RENTCAST_API_KEY=
# Optional — public-records augmentation:
# https://www.huduser.gov/portal/dataset/fmr-api.html
HUD_API_TOKEN=
# https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# ─── Email (Resend) ────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=RentVolt <noreply@groundworklabs.io>
EMAIL_REPLY_TO=support@groundworklabs.io

# ─── Session (dashboard auth) ──────────────────────────
# Required. Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# ─── Admin + cost tracking ─────────────────────────────
# Required for /api/admin/costs and /api/admin/retention. Generate with the same
# command as SESSION_SECRET.
ADMIN_TOKEN=
# RentCast per-call marginal cost in USD cents. Default 6 = Foundation overage.
RENTCAST_COST_CENTS_PER_CALL=6

# ─── Soft cost alert ───────────────────────────────────
# When month-to-date RentCast calls crosses THRESHOLD_PCT of MONTHLY_CALL_LIMIT,
# the cost-alert job emails COST_ALERT_EMAIL at most once per calendar month.
RENTCAST_MONTHLY_CALL_LIMIT=1000
COST_ALERT_THRESHOLD_PCT=70
COST_ALERT_EMAIL=support@groundworklabs.io

# ─── Observability ─────────────────────────────────────
SENTRY_DSN=
