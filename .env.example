# ─── Server ────────────────────────────────────────────
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_MAX=200

# ─── Database (Render Postgres) ────────────────────────
# Put the REAL "Internal Database URL" from Render in your .env file,
# which is gitignored. DO NOT put real credentials in .env.example —
# this file is committed to git.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# ─── Stripe ────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_GROWTH=price_xxx
STRIPE_PRICE_SCALE=price_xxx
STRIPE_PRICE_ENTERPRISE=price_xxx

# ─── Data sources ──────────────────────────────────────
# Sign up: https://app.rentcast.io/app/api
RENTCAST_API_KEY=
# Optional — public-records augmentation:
# https://www.huduser.gov/portal/dataset/fmr-api.html
HUD_API_TOKEN=
# https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# ─── Email (Resend) ────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=RentVolt <noreply@groundworklabs.io>
EMAIL_REPLY_TO=support@groundworklabs.io

# ─── Observability ─────────────────────────────────────
SENTRY_DSN=
